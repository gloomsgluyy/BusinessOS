# Business OS - Environment Variables Template
# ==============================================================================

# IMPORTANT: Database-First Mode Active! (as of April 5, 2026)
# Google Sheets is now OPTIONAL - only needed for export/backup
# Your application works fully without Sheets configured

# ------------------------------------------------------------------------------
# 1. Database Configuration (Prisma) - REQUIRED
# ------------------------------------------------------------------------------
# We are currently using SQLite. Keep it this way unless migrating later.
DATABASE_URL="file:./dev.db"

# ------------------------------------------------------------------------------
# 2. NextAuth Configuration - REQUIRED
# ------------------------------------------------------------------------------
# The secret used to sign the session cookie. In production, set this to a 
# long, random string. You can generate one with: `openssl rand -base64 32`
NEXTAUTH_SECRET="inirahasiakita123"

# The base URL of your application. Set this to the production URL in VPS.
NEXTAUTH_URL="https://production.sangkaraprasetya.site"

# ------------------------------------------------------------------------------
# 3. AI Integrations (Groq) - OPTIONAL
# ------------------------------------------------------------------------------
# Required for the AI Chatbot and Smart Meeting MOM Transcriptions.
# Add your Groq API Key below (e.g., gsk_...)
GROQ_API_KEY=""

# (Optional) Expose it to the client-side for specific browser-run components
NEXT_PUBLIC_GROQ_API_KEY=""

# ------------------------------------------------------------------------------
# 4. Google Sheets Integration - OPTIONAL (For Export/Backup Only)
# ------------------------------------------------------------------------------
# DATABASE-FIRST MODE: These are now OPTIONAL
# Set ENABLE_SHEETS_SYNC=true ONLY if you want to export data to Sheets
# Leave commented out or set to false for pure database mode

# Enable Sheets sync (false = disabled, true = export mode)
# ENABLE_SHEETS_SYNC=false

# Google Sheets ID (only needed if exporting)
# GOOGLE_SHEETS_ID=""

# Google Sheets Service Account Credentials (only needed if exporting)
# GOOGLE_SHEETS_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"..."}'

# Secret for maintenance/export endpoint (only needed if exporting)
# MAINTENANCE_SYNC_SECRET=""
