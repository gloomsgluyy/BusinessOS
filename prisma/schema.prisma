  status           String    @default("upcoming")
  buyer            String?
  supplier         String?
  iupOp            String?
  vesselName       String?
  bargeName        String?
  loadingPort      String?
  dischargePort    String?
  quantityLoaded   Float?
  blDate           DateTime?
  eta              DateTime?
  salesPrice       Float?
  marginMt         Float?
  picName          String?
  type             String    @default("export")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  allowance        String?
  analysisMethod   String?
  coaDate          DateTime?
  completelyLoaded DateTime?
  deadfreight      Float?
  demm             String?
  exportDmo        String?
  hargaActualFob   Float?
  hargaActualFobMv Float?
  hpb              Float?
  issueNotes       String?
  jarak            Float?
  jettyLoadingPort String?
  kuotaExport      String?
  laycan           String?
  lhvTerbit        DateTime?
  lossGainCargo    Float?
  mvProjectName    String?
  no               Int?
  noInvoiceMkls    String?
  noSi             String?
  noSpal           String?
  nomination       String?
  origin           String?
  pic              String?
  priceFreight     Float?
  product          String?
  qtyCob           Float?
  qtyPlan          Float?
  remarks          String?
  resultGar        Float?
  sentToBargeOwner String?
  sentToSupplier   String?
  shipmentFlow     String?
  shipmentStatus   String?
  shippingRate     Float?
  shippingTerm     String?
  source           String?
  sp               Float?
  statusHpb        String?
  surveyorLhv      String?
  year             Int       @default(2026)
  statusReason     String?
}

model SourceSupplier {
  id               String    @id @default(cuid())
  name             String
  region           String
  calorieRange     String?
  gar              Float?
  ts               Float?
  ash              Float?
  tm               Float?
  im               Float?
  fc               Float?
  nar              Float?
  adb              Float?
  jettyPort        String?
  anchorage        String?
  stockAvailable   Float     @default(0)
  minStockAlert    Float?
  kycStatus        String    @default("not_started")
  psiStatus        String    @default("not_started")
  fobBargeOnly     Boolean   @default(false)
  priceLinkedIndex String?
  fobBargePriceUsd Float?
  contractType     String?
  picName          String?
  iupNumber        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  dokumenFlow      String?
  origin           String?
  psaResultGar     Float?
  qtyProduction    Float?
  specGar          Float?
  statusDetail     String?
  updatedDate      DateTime?
}

model QualityResult {
  id           String    @id @default(cuid())
  cargoId      String
  cargoName    String
  surveyor     String?
  samplingDate DateTime?
  gar          Float?
  ts           Float?
  ash          Float?
  tm           Float?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
}

model MarketPrice {
  id             String   @id @default(cuid())
  date           DateTime
  ici1           Float?
  ici2           Float?
  ici3           Float?
  ici4           Float?
  ici5           Float?
  newcastle      Float?
  hba            Float?
  source         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false)
  avg2WeeksIci1  Float?
  avg4WeeksIci1  Float?
  avgMonthlyIci1 Float?
  changeWeekly   Float?
  hbaI           Float?
  hbaII          Float?
  hbaIII         Float?
  hpbValue       Float?
}

model DailyDelivery {
  id                 String    @id @default(cuid())
  reportType         String    @default("domestic")
  year               Int       @default(2026)
  shipmentStatus     String?
  buyer              String?
  pod                String?
  shippingTerm       String?
  latestEtaPod       DateTime?
  arriveAtPod        DateTime?
  keterlambatan      String?
  pol                String?
  laycanPol          String?
  area               String?
  supplier           String?
  mvBargeNomination  String?
  issue              String?
  blMonth            String?
  blQuantity         Float?
  blDate             DateTime?
  analysisMethod     String?
  surveyorPol        String?
  surveyorPod        String?
  project            String?
  flow               String?
  terpal             String?
  insurance          String?
  basePrice          Float?
  basePriceNotes     String?
  poMonth            String?
  product            String?
  arriveAtPol        DateTime?
  commenceLoading    DateTime?
  completeLoading    DateTime?
  startDischarging   DateTime?
  completeDischarged DateTime?
  podQuantity        Float?
  lossGainCargo      Float?
  poNo               String?
  contractNo         String?
  contractType       String?
  invoicePrice       Float?
  invoiceAmount      Float?
  paymentDueDate     DateTime?
  paymentStatus      String?
  specContract       String?
  actualGcvGar       Float?
  actualTs           Float?
  actualAsh          Float?
  actualTm           Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDeleted          Boolean   @default(false)
}

model OutstandingPayment {
  id              String    @id @default(cuid())
  perusahaan      String
  kodeBatu        String?
  priceInclPph    Float?
  qty             Float?
  totalDp         Float?
  calculationDate DateTime?
  dpToShipment    DateTime?
  timeframeDays   String?
  status          String    @default("pending")
  year            Int       @default(2026)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isDeleted       Boolean   @default(false)
}

model MeetingItem {
  id            String    @id @default(cuid())
  title         String
  date          DateTime?
  time          String?
  location      String?
  status        String    @default("scheduled")
  attendees     String?
  momContent    String?
  voiceNoteUrl  String?
  aiSummary     String?
  createdByName String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isDeleted     Boolean   @default(false)
}

model PLForecast {
  id               String   @id @default(cuid())
  dealId           String?
  dealNumber       String?
  projectName      String?
  buyer            String?
  type             String   @default("export")
  status           String   @default("forecast")
  quantity         Float    @default(0)
  sellingPrice     Float    @default(0)
  buyingPrice      Float    @default(0)
  freightCost      Float    @default(0)
  otherCost        Float    @default(0)
  grossProfitMt    Float    @default(0)
  totalGrossProfit Float    @default(0)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isDeleted        Boolean  @default(false)
}

model SalesDeal {
  id            String    @id @default(cuid())
  dealNumber    String    @unique
  status        String    @default("pre_sale")
  buyer         String
  buyerCountry  String?
  type          String    @default("export")
  shippingTerms String    @default("FOB")
  quantity      Float     @default(0)
  pricePerMt    Float?
  totalValue    Float?
  laycanStart   DateTime?
  laycanEnd     DateTime?
  vesselName    String?
  gar           Float?
  ts            Float?
  ash           Float?
  tm            Float?
  projectId     String?
  picId         String?
  picName       String?
  createdByName String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isDeleted     Boolean   @default(false)
}

model ProjectItem {
  id             String    @id @default(cuid())
  name           String
  segment        String?
  buyer          String?
  status         String    @default("waiting_approval")
  notes          String?
  createdBy      String?
  createdByName  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isDeleted      Boolean   @default(false)
  approvedBy     String?
  approvedByName String?
  approvedAt     DateTime?
}

model Partner {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("buyer")
  category      String?
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  city          String?
  country       String?
  taxId         String?
  status        String   @default("active")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)
}

model BlendingSimulation {
  id            String   @id @default(cuid())
  inputs        String   @default("[]")
  totalQuantity Float    @default(0)
  resultGar     Float    @default(0)
  resultTs      Float    @default(0)
  resultAsh     Float    @default(0)
  resultTm      Float    @default(0)
  createdBy     String
  createdAt     DateTime @default(now())
  isDeleted     Boolean  @default(false)
}
