generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CEO
  DIRUT
  ASS_DIRUT
  COO
  QQ_MANAGER
  ADMIN_OPERATION
  CMO
  TRADERS_1
  TRADERS_2_CPPO
  TRADERS_3_COO
  TRADERS_4_CMO
  JUNIOR_TRADER
  TRAFFIC_HEAD
  TRAFFIC_TEAM_1
  TRAFFIC_TEAM_2
  TRAFFIC_TEAM_3
  TRAFFIC_TEAM_4
  ADMIN_MARKETING
  QC_MANAGER
  QC_ADMIN_1
  QC_ADMIN_2
  CPPO
  SPV_SOURCING
  SOURCING_OFFICER_1
  SOURCING_OFFICER_2
  SOURCING_OFFICER_3
  SOURCING_OFFICER_4
  STAFF
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole       @default(STAFF)
  accounts      Account[]
  auditLogs     AuditLog[]
  chatHistories ChatHistory[]
  meetingMedia  MeetingMedia[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeetingMedia {
  id              String   @id @default(cuid())
  meetingId       String
  uploaderId      String
  fileName        String
  fileUrl         String
  transcribedText String?
  generatedMom    String?
  extractedTasks  String?
  createdAt       DateTime @default(now())
  uploader        User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model TimelineMilestone {
  id          String   @id @default(cuid())
  shipmentId  String
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncState {
  id           String   @id @default("singleton")
  lastSyncTime DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id               String    @id @default(cuid())
  kind             String
  recordId         String
  shipmentId       String?
  title            String
  subtitle         String?
  status           String    @default("pending")
  priority         String    @default("medium")
  href             String?
  meta             String    @default("{}")
  requestedBy      String?
  requestedByName  String?
  sourceUpdatedAt  DateTime?
  slaDueAt         DateTime?
  resolvedBy       String?
  resolvedByName   String?
  resolvedAt       DateTime?
  decisionComment  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)

  @@unique([kind, recordId])
  @@index([status])
  @@index([kind, status])
  @@index([shipmentId])
  @@index([priority, slaDueAt])
}

model TaskItem {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("todo")
  priority     String    @default("medium")
  assigneeId   String?
  assigneeName String?
  dueDate      DateTime?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
}

model SalesOrder {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  client        String
  description   String?
  amount        Float    @default(0)
  priority      String   @default("medium")
  status        String   @default("pending")
  imageUrl      String?
  createdByName String?
  createdBy     String
  approvedBy    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)
}

model PurchaseRequest {
  id            String   @id @default(cuid())
  requestNumber String   @unique
  category      String
  supplier      String?
  description   String?
  amount        Float    @default(0)
  priority      String   @default("medium")
