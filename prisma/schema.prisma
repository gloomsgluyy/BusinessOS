// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("staff") // Roles: ceo, director, manager, staff

  accounts      Account[]
  sessions      Session[]
  chatHistories ChatHistory[]
  meetingMedia  MeetingMedia[]
  auditLogs     AuditLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String
  role      String // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeetingMedia {
  id              String   @id @default(cuid())
  meetingId       String // ID from Google Sheets
  uploaderId      String
  fileName        String
  fileUrl         String
  transcribedText String?
  generatedMom    String?
  extractedTasks  String?
  createdAt       DateTime @default(now())

  uploader User @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model TimelineMilestone {
  id          String   @id @default(cuid())
  shipmentId  String
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Memory B Schema Additions ---

model SyncState {
  id           String   @id @default("singleton")
  lastSyncTime DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String // CREATE, UPDATE, DELETE
  entity    String // Task, Sales, Shipment, etc
  entityId  String
  details   String? // JSON stringified changes
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskItem {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("todo") // todo, in_progress, review, done
  priority     String    @default("medium") // low, medium, high, urgent
  assigneeId   String?
  assigneeName String?
  dueDate      DateTime?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
}

model SalesOrder {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  client        String
  description   String?
  amount        Float    @default(0)
  priority      String   @default("medium")
  status        String   @default("pending") // draft, pending, approved, rejected
  imageUrl      String?
  createdByName String?
  createdBy     String
  approvedBy    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)
}

model PurchaseRequest {
  id            String   @id @default(cuid())
  requestNumber String   @unique
  category      String
  supplier      String?
  description   String?
  amount        Float    @default(0)
  priority      String   @default("medium")
  status        String   @default("pending")
  imageUrl      String?
  createdByName String?
  createdBy     String
  approvedBy    String?
  notes         String?
  isAnomaly     Boolean  @default(false)
  anomalyReason String?
  ocrData       String? // JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)
}

// ─── MV Barge & Source (Client Excel: MV_Barge&Source) ───────────
model ShipmentDetail {
  id               String    @id @default(cuid())
  // Core identification
  no               Int?                    // NO urut
  exportDmo        String?                 // EXPORT / DMO
  status           String    @default("upcoming") // DONE SHIPMENT, UPCOMING, etc.
  origin           String?                 // ORIGIN (KALSEL, SUMSEL, KALTIM)
  mvProjectName    String?                 // MV./PROJECT NAME
  source           String?                 // SOURCE code (BME, GAT01, SERELO, etc.)
  iupOp            String?                 // IUP OP (PT Bumi Merapi Energi, etc.)
  shipmentFlow     String?                 // SHIPMENT FLOW (BME-MSE, etc.)
  jettyLoadingPort String?                 // JETTY / LOADING PORT
  laycan           String?                 // LAYCAN (text: "20-24 JAN")
  nomination       String?                 // NOMINATION (barge name)
  qtyPlan          Float?                  // QTY (MT) PLAN
  qtyCob           Float?                  // COB
  remarks          String?                 // REMARKS
  // Pricing
  hargaActualFob   Float?                  // HARGA ACTUAL FOB BARGE
  hargaActualFobMv Float?                  // HARGA ACTUAL/ASSUM FOB MV
  hpb              Float?                  // HPB
  statusHpb        String?                 // STATUS HPB
  // Shipment tracking
  shipmentStatus   String?                 // SHIPMENT STATUS
  issueNotes       String?   @db.Text      // ISSUE / NOTES
  blDate           DateTime?               // BL DATE
  pic              String?                 // PIC
  kuotaExport      String?                 // KUOTA EXPORT
  surveyorLhv      String?                 // Surveyor LHV
  completelyLoaded DateTime?               // COMPLETELY LOADED
  lhvTerbit        DateTime?               // LHV Terbit
  lossGainCargo    Float?                  // (LOSS)/GAIN CARGO
  sp               Float?                  // SP (Sales Price)
  deadfreight      Float?                  // DEADFREIGHT
  jarak            Float?                  // JARAK (NM)
  // Shipping
  shippingTerm     String?                 // SHIPPING TERM
  shippingRate     Float?                  // SHIPPING RATE
  priceFreight     Float?                  // PRICE FREIGHT
  allowance        String?                 // ALLOWANCE
  demm             String?                 // DEMM / DESP
  // Document tracking
  noSpal           String?                 // NO SPAL
  noSi             String?                 // NO SI
  sentToSupplier   String?                 // SENT TO SUPPLIER
  sentToBargeOwner String?                 // SENT TO BARGE OWNER
  noInvoiceMkls    String?                 // NO INVOICE MKLS
  // Quality
  coaDate          DateTime?               // COA DATE
  resultGar        Float?                  // RESULT GAR (ARB)
  // Legacy compat fields
  buyer            String?                 // BUYER (kept for backward compat)
  supplier         String?                 // SUPPLIER alias for source
  vesselName       String?                 // alias for mvProjectName
  bargeName        String?                 // alias for nomination
  loadingPort      String?                 // alias for jettyLoadingPort
  dischargePort    String?                 // discharge port
  quantityLoaded   Float?                  // alias for qtyPlan
  eta              DateTime?               // ETA
  salesPrice       Float?                  // alias for sp
  marginMt         Float?                  // MARGIN/MT calculated
  picName          String?                 // alias for pic
  product          String?                 // Jenis produk batubara
  analysisMethod   String?                 // Metode analisis (SGS, etc.)
  type             String    @default("export")
  // Metadata
  year             Int       @default(2026)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
}

model SourceSupplier {
  id               String   @id @default(cuid())
  name             String
  region           String
  calorieRange     String?
  gar              Float?
  ts               Float?
  ash              Float?
  tm               Float?
  im               Float?
  fc               Float?
  nar              Float?
  adb              Float?
  jettyPort        String?
  anchorage        String?
  stockAvailable   Float    @default(0)
  minStockAlert    Float?
  kycStatus        String   @default("not_started")
  psiStatus        String   @default("not_started")
  fobBargeOnly     Boolean  @default(false)
  priceLinkedIndex String?
  fobBargePriceUsd Float?
  contractType     String?
  picName          String?
  iupNumber        String?
  // New fields from Source Monitoring Excel
  origin           String?                 // ORIGIN (KALSEL, KALTIM, etc.)
  statusDetail     String?                 // Detailed status text
  updatedDate      DateTime?               // UPDATED date from monitoring
  specGar          Float?                  // SPECIFICATION GAR
  qtyProduction    Float?                  // QTY (PRODUCTION)
  dokumenFlow      String?                 // DOKUMEN FLOW
  psaResultGar     Float?                  // PSA RESULT (GAR)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isDeleted        Boolean  @default(false)
}

model QualityResult {
  id           String    @id @default(cuid())
  cargoId      String
  cargoName    String
  surveyor     String?
  samplingDate DateTime?
  gar          Float?
  ts           Float?
  ash          Float?
  tm           Float?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
}

// ─── Market Price (Client Excel: ICI HBA HPB) ──────────────────
model MarketPrice {
  id             String   @id @default(cuid())
  date           DateTime
  // ICI Indices
  ici1           Float?   // ICI 1 (GAR 6500)
  ici2           Float?   // ICI 2 (GAR 5800)
  ici3           Float?   // ICI 3 (GAR 5000)
  ici4           Float?   // ICI 4 (GAR 4200)
  ici5           Float?   // ICI 5 (GAR 3400)
  newcastle      Float?   // Newcastle/GNewc
  // HBA 4-tier (monthly)
  hba            Float?   // HBA (CV 6322 GAR) - main reference
  hbaI           Float?   // HBA I (CV 5300 GAR)
  hbaII          Float?   // HBA II (CV 4100 GAR)
  hbaIII         Float?   // HBA III (CV 3400 GAR)
  // Calculated fields
  changeWeekly   Float?   // Change Every Week (ICI 1 delta)
  avgMonthlyIci1 Float?   // Average Monthly ICI 1
  avg2WeeksIci1  Float?   // Average 2 Weeks ICI 1
  avg4WeeksIci1  Float?   // Average 4 Weeks ICI 1
  // HPB
  hpbValue       Float?   // HPB calculated value
  source         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false)
}

// ─── Daily Delivery Report (Client Excel: Daily Delivery DOM/EXP) ──
model DailyDelivery {
  id                 String    @id @default(cuid())
  reportType         String    @default("domestic") // "domestic" | "export"
  year               Int       @default(2026)
  // Core
  shipmentStatus     String?                 // Shipment Status
  buyer              String?                 // Buyer
  pod                String?                 // POD (Port of Discharge)
  shippingTerm       String?                 // Shipping Term
  latestEtaPod       DateTime?               // Latest ETA at POD
  arriveAtPod        DateTime?               // Arrive at POD
  keterlambatan      String?                 // Keterlambatan
  pol                String?                 // POL (Port of Loading)
  laycanPol          String?                 // Laycan at POL
  area               String?                 // Area
  supplier           String?                 // Supplier
  mvBargeNomination  String?                 // MV/Barge Nomination
  issue              String?   @db.Text      // Issue description
  blMonth            String?                 // BL Month
  blQuantity         Float?                  // BL Quantity
  blDate             DateTime?               // BL DATE
  analysisMethod     String?                 // Analysis Method
  surveyorPol        String?                 // Surveyor POL
  surveyorPod        String?                 // Surveyor POD
  project            String?                 // Project name
  flow               String?                 // Flow
  terpal             String?                 // Terpal
  insurance          String?                 // Insurance
  basePrice          Float?                  // Base Price
  basePriceNotes     String?                 // Base Price Notes
  poMonth            String?                 // PO Month
  product            String?                 // Product
  // Timing
  arriveAtPol        DateTime?               // Arrive at POL
  commenceLoading    DateTime?               // Commence Loading
  completeLoading    DateTime?               // Complete Loading
  startDischarging   DateTime?               // Start Discharging
  completeDischarged DateTime?               // Complete Discharged
  podQuantity        Float?                  // POD Quantity
  lossGainCargo      Float?                  // (Loss)/Gain Cargo
  // Contract/Payment
  poNo               String?                 // PO No
  contractNo         String?                 // Contract No
  contractType       String?                 // Contract w. Buyer Type (Spot/Term)
  invoicePrice       Float?                  // Invoice Price
  invoiceAmount      Float?                  // Invoice Amount
  paymentDueDate     DateTime?               // Payment Due Date
  paymentStatus      String?                 // Payment Status/Paid
  // Quality
  specContract       String?                 // SPEC CONTRACT
  actualGcvGar       Float?                  // ACTUAL GCV (GAR&GAD)
  actualTs           Float?                  // ACTUAL TS (ADB)
  actualAsh          Float?                  // ACTUAL ASH (ADB)
  actualTm           Float?                  // ACTUAL TM (ARB)
  // Metadata
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDeleted          Boolean   @default(false)
}

// ─── Outstanding Payment (Client Excel: Outstanding Payment) ───
model OutstandingPayment {
  id              String    @id @default(cuid())
  perusahaan      String                  // Nama Perusahaan
  kodeBatu        String?                 // Kode Batu
  priceInclPph    Float?                  // Price (Incl PPh, Exc. PPN)
  qty             Float?                  // Qty (MT)
  totalDp         Float?                  // Total DP
  calculationDate DateTime?               // Calculation Date of DP
  dpToShipment    DateTime?               // DP to Shipment date
  timeframeDays   String?                 // Timeframe (in days)
  status          String    @default("pending") // pending, partial, paid
  year            Int       @default(2026)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isDeleted       Boolean   @default(false)
}

model MeetingItem {
  id            String    @id @default(cuid())
  title         String
  date          DateTime?
  time          String?
  location      String?
  status        String    @default("scheduled")
  attendees     String? // JSON array
  momContent    String? // Plain text MOM transcript
  voiceNoteUrl  String? // URL to uploaded audio/video
  aiSummary     String? // AI-generated summary (markdown)
  createdByName String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isDeleted     Boolean   @default(false)
}

model PLForecast {
  id               String   @id @default(cuid())
  dealId           String?
  dealNumber       String?
  projectName      String?
  buyer            String?
  type             String   @default("export")
  status           String   @default("forecast")
  quantity         Float    @default(0)
  sellingPrice     Float    @default(0)
  buyingPrice      Float    @default(0)
  freightCost      Float    @default(0)
  otherCost        Float    @default(0)
  grossProfitMt    Float    @default(0)
  totalGrossProfit Float    @default(0)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isDeleted        Boolean  @default(false)
}

model SalesDeal {
  id            String    @id @default(cuid())
  dealNumber    String    @unique
  status        String    @default("pre_sale")
  buyer         String
  buyerCountry  String?
  type          String    @default("export")
  shippingTerms String    @default("FOB")
  quantity      Float     @default(0)
  pricePerMt    Float?
  totalValue    Float?
  laycanStart   DateTime?
  laycanEnd     DateTime?
  vesselName    String?
  gar           Float?
  ts            Float?
  ash           Float?
  tm            Float?
  projectId     String?
  picId         String?
  picName       String?
  createdByName String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isDeleted     Boolean   @default(false)
}

model Partner {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("buyer") // buyer, vendor, fleet
  category      String?
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  city          String?
  country       String?
  taxId         String?
  status        String   @default("active") // active, under_review, inactive
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)
}

model BlendingSimulation {
  id            String   @id @default(cuid())
  inputs        String   @default("[]") // JSON array of { name, quantity, gar, ts, ash, tm }
  totalQuantity Float    @default(0)
  resultGar     Float    @default(0)
  resultTs      Float    @default(0)
  resultAsh     Float    @default(0)
  resultTm      Float    @default(0)
  createdBy     String
  createdAt     DateTime @default(now())
  isDeleted     Boolean  @default(false)
}
